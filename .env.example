# Supabase - Public (safe for frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase - Secret (NEVER expose to frontend/browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Price APIs (server-side only)
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key
TWELVE_DATA_API_KEY=your-twelve-data-key
# CoinGecko is free, no key needed for basic usage
# COINGECKO_API_KEY=your-coingecko-key (for pro plan)

# App URL (used for CORS)
NEXT_PUBLIC_APP_URL=http://localhost:3000
